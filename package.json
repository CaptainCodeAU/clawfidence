{
  "name": "clawfidence",
  "version": "1.0.0",
  "description": "First responder for your Markdown pipeline. Defangs prompt injection, strips XSS, and sanitises HTML.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "clawfidence": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:xss-payloads": "vitest run test/xss-payloads.test.ts",
    "test:cve": "vitest run test/xss-payloads.test.ts -t CVE"
  },
  "keywords": [
    "markdown",
    "sanitise",
    "xss",
    "llm",
    "prompt-injection"
  ],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.29.3",
  "devDependencies": {
    "@types/node": "^25.3.1",
    "@vitest/coverage-v8": "^4.0.18",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@types/jsdom": "^21.1.7",
    "@types/markdown-it": "^14.1.2",
    "@types/turndown": "^5.0.6",
    "commander": "^14.0.3",
    "defuddle": "^0.7.0",
    "dompurify": "^3.3.1",
    "jsdom": "^24.1.3",
    "markdown-it": "^14.1.1",
    "turndown": "^7.2.2",
    "turndown-plugin-gfm": "^1.0.2"
  }
}
